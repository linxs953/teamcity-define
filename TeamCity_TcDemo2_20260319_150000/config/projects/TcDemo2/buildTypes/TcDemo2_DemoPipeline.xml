<?xml version="1.0" encoding="UTF-8"?>
<build-type xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" uuid="c1fb6f7b-5b8f-4a21-9e7d-3fd0a2e1c329" xsi:noNamespaceSchemaLocation="https://www.jetbrains.com/teamcity/schemas/2025.3/project-config.xsd">
  <name>单元测试</name>
  <description />
  <settings>
    <options>
      <option name="artifactRules" value="**\bin\Release\** =&gt; demodist\ReleaseLib\&#xA;**\obj\Release\** =&gt; demodist\ReleaseObj\&#xA;Report_*.html =&gt; demodist\unittest\&#xA;TestResult_*.xml =&gt; demodist\unittest\" />
      <option name="buildNumberPattern" value="1.0.%build.counter%+CL%build.vcs.number.TcDemo2_TcDemo2%" />
      <option name="cleanBuild" value="true" />
      <option name="executionTimeoutMin" value="1" />
      <option name="publishArtifactCondition" value="SUCCESSFUL" />
      <option name="showDependenciesChanges" value="true" />
    </options>
    <disabled-settings>
      <setting-ref ref="fu_gai_lv" />
    </disabled-settings>
    <parameters>
      <param name="DotNetCLI_Path" value="C:\Program Files\dotnet\dotnet.exe" />
    </parameters>
    <build-runners>
      <runner id="ce_shi" name="单元测试" type="simpleRunner">
        <parameters>
          <param name="script.content" value="D:\\NUnit.Console-3.22.0\\bin\\net462\\nunit3-console.exe tc2\\tc2-test\\bin\\Debug\\tc2_test.dll --result:TestResult_CL-%build.vcs.number.TcDemo2_TcDemo2%.xml" />
          <param name="teamcity.step.mode" value="default" />
          <param name="use.custom.script" value="true" />
        </parameters>
      </runner>
      <runner id="bao_gao" name="生成单元测试报告" type="jetbrains_powershell">
        <parameters>
          <param name="jetbrains_powershell_execution" value="PS1" />
          <param name="jetbrains_powershell_noprofile" value="true" />
          <param name="jetbrains_powershell_scriptArguments" value="--XmlPath TestResult_CL-%build.vcs.number.TcDemo2_TcDemo2%.xml --HtmlPath Report_CL-%build.vcs.number.TcDemo2_TcDemo2%.html" />
          <param name="jetbrains_powershell_script_file" value="C:\TeamCity\scripts\Convert-NUnitXmlToHtml.ps1" />
          <param name="jetbrains_powershell_script_mode" value="FILE" />
          <param name="teamcity.step.mode" value="default" />
        </parameters>
      </runner>
      <runner id="dotnet" name="构建项目" type="dotnet">
        <parameters>
          <param name="args" value="-t:Clean;Build;Publish -p:Configuration=Release -v:detailed -property:ConsoleEncoding=utf-8" />
          <param name="command" value="msbuild" />
          <param name="dotNetCoverage.dotCover.home.path" value="%teamcity.tool.JetBrains.dotCover.CommandLineTools.DEFAULT%" />
          <param name="msbuild.version" value="MSBuild_4_Windows" />
          <param name="paths" value="tc2/tc2.sln" />
          <param name="required.sdk" value="4.8" />
          <param name="teamcity.step.mode" value="default" />
        </parameters>
      </runner>
      <runner id="fu_gai_lv" name="统计覆盖率" type="dotcover">
        <parameters>
          <param name="dotNetCoverage.dotCover.coveredProcessArguments" value="test --framework net48" />
          <param name="dotNetCoverage.dotCover.coveredProcessExecutable" value="C:\\Program Files\\dotnet\\dotnet.exe" />
          <param name="dotNetCoverage.dotCover.generateReport" value="true" />
          <param name="dotNetCoverage.dotCover.home.path" value="%teamcity.tool.JetBrains.dotCover.CommandLineTools.DEFAULT%" />
          <param name="dotNetCoverage.tool" value="dotcover" />
          <param name="teamcity.step.mode" value="default" />
        </parameters>
      </runner>
    </build-runners>
    <vcs-settings>
      <vcs-entry-ref root-id="TcDemo2_TcDemo2" />
    </vcs-settings>
    <build-triggers>
      <build-trigger id="TRIGGER_4" type="vcsTrigger">
        <parameters>
          <param name="branchFilter" value="+:*" />
          <param name="enableQueueOptimization" value="true" />
          <param name="quietPeriodMode" value="DO_NOT_USE" />
        </parameters>
      </build-trigger>
      <build-trigger id="TRIGGER_6" type="buildDependencyTrigger">
        <parameters>
          <param name="branchFilter" value="+:&lt;default&gt;" />
          <param name="dependsOn" value="TcDemo2_Build2" />
        </parameters>
      </build-trigger>
    </build-triggers>
    <build-extensions>
      <extension id="perfmon" type="perfmon" />
      <extension id="BUILD_EXT_1" type="xml-report-plugin">
        <parameters>
          <param name="xmlReportParsing.reportDirs" value="TestResult_*.xml" />
          <param name="xmlReportParsing.reportType" value="nunit" />
          <param name="xmlReportParsing.verboseOutput" value="true" />
        </parameters>
      </extension>
    </build-extensions>
  </settings>
</build-type>
